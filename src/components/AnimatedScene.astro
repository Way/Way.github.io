            <rect x={m.cx - m.size * 0.5} y={m.cy - m.size * 0.5}
              width={m.size} height={m.size}
              fill="none" stroke="rgba(120, 180, 240, 0.2)" stroke-width="0.8"
              transform={`rotate(45 ${m.cx} ${m.cy})`} />
          )}
        </g>
      ))}
    </g>
  )}

  {theme === 'signal' && (
    <g class="sig-scene">
      {/* Connection lines between emitters */}
      {signalLinks.map((l) => (
        <line
          x1={l.x1.toFixed(1)}
          y1={l.y1.toFixed(1)}
          x2={l.x2.toFixed(1)}
          y2={l.y2.toFixed(1)}
          stroke="rgba(255, 180, 100, 0.12)"
          stroke-width="0.8"
          stroke-dasharray="4 6"
          class="sig-link"
          style={`animation-delay: ${l.delay}s`}
        />
      ))}
      {/* Emitters with rings */}
      {emitters.map((e) => (
        <g class="sig-emitter" style={`animation-delay: ${e.delay}s`}>
          {/* Concentric rings */}
          {Array.from({ length: e.ringCount }, (_, r) => (
            <circle
              cx={e.cx.toFixed(1)}
              cy={e.cy.toFixed(1)}
              r={(e.maxR * ((r + 1) / e.ringCount)).toFixed(1)}
              fill="none"
              stroke={`hsla(${e.hue}, 60%, 55%, ${(0.2 - r * 0.04).toFixed(2)})`}
              stroke-width="0.8"
              class="sig-ring"
              style={`animation-delay: ${(parseFloat(e.delay) + r * 0.4).toFixed(1)}s; --ring-scale: ${1 + r * 0.15}`}
            />
          ))}
          {/* Core emitter */}
          <circle
            cx={e.cx.toFixed(1)}
            cy={e.cy.toFixed(1)}
            r="4"
            fill={`hsla(${e.hue}, 65%, 55%, 0.7)`}
            class="sig-core"
            style={`animation-delay: ${e.delay}s`}
          />
          {/* Inner glow */}
          <circle
            cx={e.cx.toFixed(1)}
            cy={e.cy.toFixed(1)}
            r="8"
            fill={`hsla(${e.hue}, 55%, 50%, 0.1)`}
            class="sig-glow"
            style={`animation-delay: ${e.delay}s`}
          />
        </g>
      ))}
    </g>
  )}

  {theme === 'cockpit' && (
    <g class="cp-scene">
      {/* Connection lines between panels */}
      {cpLinks.map((l) => (
        <line
          x1={l.x1.toFixed(1)} y1={l.y1.toFixed(1)}
          x2={l.x2.toFixed(1)} y2={l.y2.toFixed(1)}
          stroke="rgba(140, 160, 255, 0.1)"
          stroke-width="0.8"
          stroke-dasharray="4 8"
          class="cp-link"
          style={`animation-delay: ${l.delay}s`}
        />
      ))}
      {/* Panels */}
      {cpPanels.map((p) => (
        <g class="cp-panel" style={`animation-delay: ${p.delay}s`}>
          <rect
            x={p.x.toFixed(1)} y={p.y.toFixed(1)}
            width={p.w.toFixed(1)} height={p.h.toFixed(1)}
            rx="5"
            fill={`hsla(${p.hue}, 40%, 20%, 0.15)`}
            stroke={`hsla(${p.hue}, 45%, 45%, 0.25)`}
            stroke-width="1"
          />
          {/* Panel header bar */}
          <rect
            x={(p.x + 6).toFixed(1)} y={(p.y + 5).toFixed(1)}
            width={(p.w * 0.4).toFixed(1)} height="2.5"
            rx="1"
            fill={`hsla(${p.hue}, 50%, 55%, 0.3)`}
          />
        </g>
      ))}
      {/* Gauges */}
      {cpGauges.map((g) => (
        <g class="cp-gauge" style={`animation-delay: ${g.delay}s`}>
          <circle
            cx={g.cx.toFixed(1)} cy={g.cy.toFixed(1)}
            r={g.r.toFixed(1)}
            fill="none"
            stroke={`hsla(${g.hue}, 35%, 40%, 0.2)`}
            stroke-width="1.5"
          />
          <circle
            cx={g.cx.toFixed(1)} cy={g.cy.toFixed(1)}
            r={g.r.toFixed(1)}
            fill="none"
            stroke={`hsla(${g.hue}, 55%, 60%, 0.5)`}
            stroke-width="1.5"
            stroke-dasharray={`${(g.fill * Math.PI * 2 * g.r).toFixed(1)} ${(Math.PI * 2 * g.r).toFixed(1)}`}
            stroke-linecap="round"
            transform={`rotate(-90 ${g.cx.toFixed(1)} ${g.cy.toFixed(1)})`}
            class="cp-gauge-fill"
            style={`animation-delay: ${g.delay}s`}
          />
          <circle
            cx={g.cx.toFixed(1)} cy={g.cy.toFixed(1)}
            r="1.5"
            fill={`hsla(${g.hue}, 60%, 65%, 0.7)`}
            class="cp-gauge-dot"
            style={`animation-delay: ${g.delay}s`}
          />
        </g>
      ))}
      {/* Status dots */}
      {cpDots.map((d) => (
        <circle
          cx={d.cx.toFixed(1)} cy={d.cy.toFixed(1)}
          r={d.r.toFixed(1)}
          fill={`hsla(${d.hue}, 55%, 55%, 0.6)`}
          class="cp-dot"
          style={`animation-delay: ${d.delay}s`}
        />
      ))}
    </g>
  )}

  {theme === 'scaffold' && (
    <g class="sc-scene">
      {/* Connection lines */}
      {scLinks.map((l) => (
        <line
          x1={l.x1.toFixed(1)} y1={l.y1.toFixed(1)}
          x2={l.x2.toFixed(1)} y2={l.y2.toFixed(1)}
          stroke="rgba(180, 160, 255, 0.15)"
          stroke-width="1"
          class="sc-link"
          style={`animation-delay: ${l.delay}s`}
        />
      ))}
      {/* Modules */}
      {scModules.map((m) => (
        <g class="sc-module" style={`animation-delay: ${m.delay}s`}>
          <rect
            x={m.x.toFixed(1)} y={m.y.toFixed(1)}
            width={m.w.toFixed(1)} height={m.h.toFixed(1)}
            rx="4"
            fill={`hsla(${m.hue}, 35%, ${m.lightness}%, 0.2)`}
            stroke={`hsla(${m.hue}, 40%, ${m.lightness + 20}%, 0.3)`}
            stroke-width="1"
            class="sc-block"
            style={`animation-delay: ${m.delay}s`}
          />
          {/* Inner detail bars */}
          <rect
            x={(m.x + m.w * 0.1).toFixed(1)}
            y={(m.y + m.h * 0.3).toFixed(1)}
            width={(m.w * 0.3).toFixed(1)}
            height="2"
            rx="1"
            fill={`hsla(${m.hue}, 45%, 50%, 0.15)`}
          />
          <rect
            x={(m.x + m.w * 0.1).toFixed(1)}
            y={(m.y + m.h * 0.6).toFixed(1)}
            width={(m.w * 0.5).toFixed(1)}
            height="2"
            rx="1"
            fill={`hsla(${m.hue}, 45%, 50%, 0.25)`}
          />
        </g>
      ))}
      {/* Connectors */}
      {scConnectors.map((c) => (
        <circle
          cx={c.cx.toFixed(1)} cy={c.cy.toFixed(1)}
          r="2.5"
          fill="rgba(200, 180, 255, 0.15)"
          stroke="rgba(200, 180, 255, 0.35)"
          stroke-width="0.8"
          class="sc-connector"
          style={`animation-delay: ${c.delay}s`}
        />
      ))}
    </g>
  )}

  {theme === 'orbit' && (
    <g class="ob-scene">
      {/* Orbital paths */}
      {orbitRings.map((ring) => (
        <ellipse
          cx={orbitCx.toFixed(1)} cy={orbitCy.toFixed(1)}
          rx={ring.rx.toFixed(1)} ry={ring.ry.toFixed(1)}
          fill="none"
          stroke="rgba(180, 160, 255, 0.1)"
          stroke-width="0.8"
          stroke-dasharray="3 6"
          transform={`rotate(${ring.rotation} ${orbitCx.toFixed(1)} ${orbitCy.toFixed(1)})`}
          class="ob-ring"
          style={`animation-delay: ${ring.delay}s`}
        />
      ))}
      {/* Links from satellites to center */}
      {orbitLinks.map((l) => (
        <line
          x1={l.x1.toFixed(1)} y1={l.y1.toFixed(1)}
          x2={l.x2.toFixed(1)} y2={l.y2.toFixed(1)}
          stroke="rgba(160, 140, 255, 0.08)"
          stroke-width="0.6"
          class="ob-link"
          style={`animation-delay: ${l.delay}s`}
        />
      ))}
      {/* Center core */}
      <circle
        cx={orbitCx.toFixed(1)} cy={orbitCy.toFixed(1)}
        r="20"
        fill="rgba(180, 160, 255, 0.05)"
        class="ob-core-glow"
      />
      <circle
        cx={orbitCx.toFixed(1)} cy={orbitCy.toFixed(1)}
        r="12"
        fill="none"
        stroke="rgba(180, 160, 255, 0.15)"
        stroke-width="1"
        class="ob-core-ring"
      />
      <circle
        cx={orbitCx.toFixed(1)} cy={orbitCy.toFixed(1)}
        r="5"
        fill="rgba(200, 180, 255, 0.6)"
        class="ob-core"
      />
      {/* Satellites */}
      {orbitSats.map((s) => (
        <g class="ob-sat" style={`animation-delay: ${s.delay}s; --drift: ${s.drift}px`}>
          <circle
            cx={s.cx.toFixed(1)} cy={s.cy.toFixed(1)}
            r={(s.r * 2).toFixed(1)}
            fill="none"
            stroke={`hsla(${s.hue}, 45%, 55%, 0.12)`}
            stroke-width="0.8"
            class="ob-sat-ring"
            style={`animation-delay: ${s.delay}s`}
          />
          <circle
            cx={s.cx.toFixed(1)} cy={s.cy.toFixed(1)}
            r={s.r.toFixed(1)}
            fill={`hsla(${s.hue}, 50%, 55%, 0.6)`}
            class="ob-sat-core"
            style={`animation-delay: ${s.delay}s`}
          />
        </g>
      ))}
    </g>
  )}
</svg>

<style>
