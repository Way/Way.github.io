---
interface Props {
  theme: 'neural-network' | 'mesh' | 'towers' | 'growth' | 'vertical-stack' | 'roundtable' | 'pipeline' | 'swarm' | 'blueprint' | 'signal' | 'cockpit' | 'scaffold' | 'orbit';
  seed: number;
  width: number;
  height: number;
}

const { theme, seed, width, height } = Astro.props;

/** Deterministic pseudo-random 0..1 */
function srand(s: number, i: number): number {
  const x = Math.sin(s * 9301 + i * 49297) * 49979;
  return x - Math.floor(x);
}

// --- Neural Network nodes + connections ---
const nodeCount = 10;
const nodes = Array.from({ length: nodeCount }, (_, i) => ({
  cx: 40 + srand(seed, i * 5) * (width - 80),
  cy: 20 + srand(seed, i * 5 + 1) * (height - 40),
  r: 3 + srand(seed, i * 5 + 2) * 4,
  delay: (srand(seed, i * 5 + 3) * 4).toFixed(1),
  drift: 6 + srand(seed, i * 5 + 4) * 8,
}));

// Connect nearby nodes
const connections: Array<{ x1: number; y1: number; x2: number; y2: number; delay: string }> = [];
for (let i = 0; i < nodes.length; i++) {
  for (let j = i + 1; j < nodes.length; j++) {
    const dx = nodes[i].cx - nodes[j].cx;
    const dy = nodes[i].cy - nodes[j].cy;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < Math.min(width, height) * 0.4) {
      connections.push({
        x1: nodes[i].cx,
        y1: nodes[i].cy,
        x2: nodes[j].cx,
        y2: nodes[j].cy,
        delay: ((i + j) * 0.3).toFixed(1),
      });
    }
  }
}

// --- Mesh points + connections ---
const meshCount = 14;
const meshPoints = Array.from({ length: meshCount }, (_, i) => ({
  cx: 30 + srand(seed + 100, i * 4) * (width - 60),
  cy: 15 + srand(seed + 100, i * 4 + 1) * (height - 30),
  delay: (srand(seed + 100, i * 4 + 2) * 5).toFixed(1),
  driftX: -10 + srand(seed + 100, i * 4 + 3) * 20,
  driftY: -8 + srand(seed + 100, i * 4 + 2) * 16,
}));

const meshLines: Array<{ x1: number; y1: number; x2: number; y2: number; delay: string }> = [];
for (let i = 0; i < meshPoints.length; i++) {
  for (let j = i + 1; j < meshPoints.length; j++) {
    const dx = meshPoints[i].cx - meshPoints[j].cx;
    const dy = meshPoints[i].cy - meshPoints[j].cy;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < Math.min(width, height) * 0.5) {
      meshLines.push({
        x1: meshPoints[i].cx,
        y1: meshPoints[i].cy,
        x2: meshPoints[j].cx,
        y2: meshPoints[j].cy,
        delay: (srand(seed + 200, i + j) * 6).toFixed(1),
      });
    }
  }
}

// --- Towers ---
const towerCount = 7;
const towers = Array.from({ length: towerCount }, (_, i) => {
  const tw = width / (towerCount + 2);
  const maxH = height * 0.85;
  const h = maxH * (0.3 + srand(seed + 300, i) * 0.7);
  return {
    x: tw * (i + 1) - tw * 0.35,
    y: height - h,
    w: tw * 0.7,
    h: h,
    delay: (i * 0.2).toFixed(1),
    hue: Math.round(260 + srand(seed + 300, i + 10) * 40),
    lightness: Math.round(25 + srand(seed + 300, i + 20) * 20),
  };
});
// --- Growth: organic branching paths ---
const branchCount = 6;
const startX = width * 0.15;
const startY = height * 0.6;
const branches = Array.from({ length: branchCount }, (_, i) => {
  const angle = -30 + srand(seed + 400, i * 3) * -120; // upward spread
  const len = 40 + srand(seed + 400, i * 3 + 1) * (Math.min(width, height) * 0.5);
  const rad = (angle * Math.PI) / 180;
  const endX = startX + Math.cos(rad) * len;
  const endY = startY + Math.sin(rad) * len;
  // Control point for curve
  const cpX = startX + Math.cos(rad) * len * 0.5 + (srand(seed + 400, i * 3 + 2) - 0.5) * 60;
  const cpY = startY + Math.sin(rad) * len * 0.5 + (srand(seed + 400, i * 3 + 2) - 0.5) * 40;
  const pathLen = Math.round(len * 1.3);
  return {
    d: `M${startX.toFixed(1)},${startY.toFixed(1)} Q${cpX.toFixed(1)},${cpY.toFixed(1)} ${endX.toFixed(1)},${endY.toFixed(1)}`,
    endX,
    endY,
    delay: (i * 0.4).toFixed(1),
    dashLen: pathLen,
    leafR: 4 + srand(seed + 400, i + 20) * 5,
    hue: Math.round(140 + srand(seed + 400, i + 30) * 80), // green to teal
  };
});

// --- Growth: main trunk (central stem) ---
const trunkTopY = height * 0.08;
const trunkMid1Y = startY * 0.7;
const trunkMid2Y = startY * 0.35;
const trunkSway1 = (srand(seed + 410, 0) - 0.5) * 30;
const trunkSway2 = (srand(seed + 410, 1) - 0.5) * 20;
const trunk = {
  d: `M${startX.toFixed(1)},${startY.toFixed(1)} C${(startX + trunkSway1).toFixed(1)},${trunkMid1Y.toFixed(1)} ${(startX - trunkSway2).toFixed(1)},${trunkMid2Y.toFixed(1)} ${(startX + trunkSway1 * 0.3).toFixed(1)},${trunkTopY.toFixed(1)}`,
  dashLen: Math.round((startY - trunkTopY) * 1.4),
  hue: 145,
};

// --- Growth: sub-branches forking from main branches ---
const subBranches = branches.flatMap((b, i) => {
  if (srand(seed + 420, i * 10) < 0.3) return [];
  const forkT = 0.4 + srand(seed + 420, i * 10 + 1) * 0.2;
  const forkX = startX + (b.endX - startX) * forkT;
  const forkY = startY + (b.endY - startY) * forkT;
  const parentAngle = Math.atan2(b.endY - startY, b.endX - startX);
  const branchAngle = parentAngle + (srand(seed + 420, i * 10 + 2) > 0.5 ? 1 : -1)
    * (0.5 + srand(seed + 420, i * 10 + 3) * 0.8);
  const subLen = 15 + srand(seed + 420, i * 10 + 4) * 25;
  const tipX = forkX + Math.cos(branchAngle) * subLen;
  const tipY = forkY + Math.sin(branchAngle) * subLen;
  const scpX = forkX + Math.cos(branchAngle) * subLen * 0.5
    + (srand(seed + 420, i * 10 + 5) - 0.5) * 10;
  const scpY = forkY + Math.sin(branchAngle) * subLen * 0.5
    + (srand(seed + 420, i * 10 + 5) - 0.5) * 8;
  return [{
    d: `M${forkX.toFixed(1)},${forkY.toFixed(1)} Q${scpX.toFixed(1)},${scpY.toFixed(1)} ${tipX.toFixed(1)},${tipY.toFixed(1)}`,
    tipX,
    tipY,
    dashLen: Math.round(subLen * 1.3),
    delay: (parseFloat(b.delay) + 0.8).toFixed(1),
    budR: 2 + srand(seed + 420, i * 10 + 6) * 1.5,
    hue: b.hue + Math.round((srand(seed + 420, i * 10 + 7) - 0.5) * 20),
  }];
});

// --- Growth: floating spores/particles ---
const sporeCount = 8 + Math.floor(srand(seed + 430, 0) * 5);
const spores = Array.from({ length: sporeCount }, (_, i) => ({
  cx: 20 + srand(seed + 430, i * 4) * (width - 40),
  cy: height * 0.15 + srand(seed + 430, i * 4 + 1) * (height * 0.7),
  r: 1 + srand(seed + 430, i * 4 + 2) * 1.5,
  opacity: 0.08 + srand(seed + 430, i * 4 + 3) * 0.17,
  duration: (12 + srand(seed + 430, i * 4 + 2) * 10).toFixed(1),
  delay: (srand(seed + 430, i * 4 + 3) * 6).toFixed(1),
  drift: (15 + srand(seed + 430, i * 4 + 1) * 20).toFixed(1),
  hue: Math.round(140 + srand(seed + 430, i * 4) * 60),
}));

// --- Growth: ground roots ---
const rootCount = 3 + Math.floor(srand(seed + 440, 0) * 2);
const groundRoots = Array.from({ length: rootCount }, (_, i) => {
  const angle = 10 + srand(seed + 440, i * 3) * 50;
  const side = (i % 2 === 0) ? 1 : -1;
  const len = 25 + srand(seed + 440, i * 3 + 1) * 40;
  const rad = (angle * Math.PI) / 180;
  const endX = startX + side * Math.cos(rad) * len;
  const endY = startY + Math.sin(rad) * len;
  const cpX = startX + side * Math.cos(rad) * len * 0.5
    + (srand(seed + 440, i * 3 + 2) - 0.5) * 15;
  const cpY = startY + Math.sin(rad) * len * 0.5
    + srand(seed + 440, i * 3 + 2) * 10;
  const pathLen = Math.round(len * 1.2);
  return {
    d: `M${startX.toFixed(1)},${startY.toFixed(1)} Q${cpX.toFixed(1)},${cpY.toFixed(1)} ${endX.toFixed(1)},${endY.toFixed(1)}`,
    dashLen: pathLen,
    delay: (0.3 + i * 0.3).toFixed(1),
    hue: Math.round(130 + srand(seed + 440, i + 10) * 30),
  };
});

// --- Growth: bloom cluster data for branch tips ---
const bloomData = branches.map((b, i) => {
  const hasBloom = srand(seed + 450, i) > 0.45;
  if (!hasBloom) return null;
  const petalCount = 3 + Math.floor(srand(seed + 450, i * 5 + 1) * 3);
  const petals = Array.from({ length: petalCount }, (_, p) => {
    const angle = (Math.PI * 2 * p) / petalCount
      + srand(seed + 450, i * 5 + p + 2) * 0.3;
    const dist = b.leafR * 0.55;
    const petalR = b.leafR * (0.4 + srand(seed + 450, i * 5 + p + 10) * 0.15);
    return {
      cx: b.endX + Math.cos(angle) * dist,
      cy: b.endY + Math.sin(angle) * dist,
      r: petalR,
    };
  });
  return {
    petals,
    centerR: b.leafR * 0.3,
    hue: b.hue + 15,
  };
});

// --- Vertical Stack: horizontal layers ---
const layerCount = 5;
const layerGap = height / (layerCount + 1);
const layers = Array.from({ length: layerCount }, (_, i) => {
  const lw = width * (0.35 + srand(seed + 500, i) * 0.45);
  const lx = (width - lw) / 2;
  const ly = layerGap * (i + 0.5);
  return {
    x: lx,
    y: ly,
    w: lw,
    h: layerGap * 0.45,
    delay: (i * 0.25).toFixed(1),
    hue: Math.round(260 + i * 12),
    lightness: Math.round(22 + i * 7),
  };
});

// Arrows connecting layers
const layerArrows = layers.slice(0, -1).map((l, i) => {
  const next = layers[i + 1];
  const cx = width / 2;
  const y1 = l.y + l.h;
  const y2 = next.y;
  return { cx, y1, y2, delay: ((i + 1) * 0.3).toFixed(1) };
});

// --- Roundtable: seats arranged in an ellipse ---
const seatCount = 8;
const tableCx = width / 2;
const tableCy = height / 2;
const tableRx = width * 0.34;
const tableRy = height * 0.32;
const seats = Array.from({ length: seatCount }, (_, i) => {
  const angle = (Math.PI * 2 * i) / seatCount - Math.PI / 2;
  const isAgent = i % 2 === 1; // alternate human / agent
  return {
    cx: tableCx + Math.cos(angle) * tableRx,
    cy: tableCy + Math.sin(angle) * tableRy,
    r: 5 + srand(seed + 600, i) * 3,
    isAgent,
    delay: (i * 0.15).toFixed(1),
    drift: 3 + srand(seed + 600, i + 20) * 4,
    hue: isAgent ? Math.round(250 + srand(seed + 600, i + 10) * 30) : Math.round(30 + srand(seed + 600, i + 10) * 20),
  };
});

// Connect each seat to its neighbors + cross-table pairs
const seatLines: Array<{ x1: number; y1: number; x2: number; y2: number; delay: string; isActive: boolean }> = [];
for (let i = 0; i < seatCount; i++) {
  // Neighbor connection
  const next = (i + 1) % seatCount;
  seatLines.push({
    x1: seats[i].cx, y1: seats[i].cy,
    x2: seats[next].cx, y2: seats[next].cy,
    delay: (i * 0.2).toFixed(1),
    isActive: false,
  });
  // Cross-table connection (every other)
  if (i < seatCount / 2) {
    const opposite = (i + Math.floor(seatCount / 2)) % seatCount;
    seatLines.push({
      x1: seats[i].cx, y1: seats[i].cy,
      x2: seats[opposite].cx, y2: seats[opposite].cy,
      delay: (i * 0.3 + 0.5).toFixed(1),
      isActive: seats[i].isAgent !== seats[opposite].isAgent,
    });
  }
}

// --- Pipeline: flowing stages connected by paths ---
const stageCount = 5;
const stageSpacing = width / (stageCount + 1);
const stages = Array.from({ length: stageCount }, (_, i) => {
  const cx = stageSpacing * (i + 1);
  const cy = height * (0.35 + srand(seed + 700, i) * 0.3);
  const r = 10 + srand(seed + 700, i + 10) * 8;
  return {
    cx,
    cy,
    r,
    delay: (i * 0.3).toFixed(1),
    hue: Math.round(200 + srand(seed + 700, i + 20) * 60),
    lightness: Math.round(30 + srand(seed + 700, i + 30) * 15),
  };
});

const pipeLines = stages.slice(0, -1).map((s, i) => {
  const next = stages[i + 1];
  const cpX = (s.cx + next.cx) / 2;
  const cpY = (s.cy + next.cy) / 2 + (srand(seed + 710, i) - 0.5) * 40;
  return {
    d: `M${s.cx.toFixed(1)},${s.cy.toFixed(1)} Q${cpX.toFixed(1)},${cpY.toFixed(1)} ${next.cx.toFixed(1)},${next.cy.toFixed(1)}`,
    delay: (i * 0.3 + 0.5).toFixed(1),
    dashLen: Math.round(Math.sqrt((next.cx - s.cx) ** 2 + (next.cy - s.cy) ** 2) * 1.3),
  };
});

// Data particles flowing along pipes
const particleCount = 8;
const pipeParticles = Array.from({ length: particleCount }, (_, i) => {
  const pipeIdx = Math.floor(srand(seed + 720, i) * pipeLines.length);
  const pipe = pipeLines[pipeIdx];
  return {
    pipeIdx,
    r: 1.5 + srand(seed + 720, i + 10) * 1.5,
    duration: (3 + srand(seed + 720, i + 20) * 4).toFixed(1),
    delay: (srand(seed + 720, i + 30) * 5).toFixed(1),
    hue: stages[pipeIdx].hue,
  };
});

// --- Swarm: autonomous agents moving in coordinated patterns ---
const swarmCount = 18;
const swarmAgents = Array.from({ length: swarmCount }, (_, i) => {
  const cx = 40 + srand(seed + 800, i * 6) * (width - 80);
  const cy = 30 + srand(seed + 800, i * 6 + 1) * (height - 60);
  const isLeader = i < 3;
  return {
    cx,
    cy,
    r: isLeader ? 4 + srand(seed + 800, i * 6 + 2) * 2 : 2 + srand(seed + 800, i * 6 + 2) * 1.5,
    isLeader,
    delay: (srand(seed + 800, i * 6 + 3) * 3).toFixed(1),
    driftX: (-20 + srand(seed + 800, i * 6 + 4) * 40).toFixed(1),
    driftY: (-15 + srand(seed + 800, i * 6 + 5) * 30).toFixed(1),
    duration: (6 + srand(seed + 800, i * 6 + 2) * 8).toFixed(1),
    hue: isLeader
      ? Math.round(270 + srand(seed + 800, i + 40) * 30)
      : Math.round(180 + srand(seed + 800, i + 40) * 60),
  };
});

// Swarm communication lines between nearby agents
const swarmLines: Array<{ x1: number; y1: number; x2: number; y2: number; delay: string }> = [];
for (let i = 0; i < swarmAgents.length; i++) {
  for (let j = i + 1; j < swarmAgents.length; j++) {
    const dx = swarmAgents[i].cx - swarmAgents[j].cx;
    const dy = swarmAgents[i].cy - swarmAgents[j].cy;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < Math.min(width, height) * 0.25) {
      swarmLines.push({
        x1: swarmAgents[i].cx,
        y1: swarmAgents[i].cy,
        x2: swarmAgents[j].cx,
        y2: swarmAgents[j].cy,
        delay: (srand(seed + 810, i + j) * 4).toFixed(1),
      });
    }
  }
}

// --- Blueprint: technical grid with schematic elements ---
const gridSpacingX = width / 8;
const gridSpacingY = height / 5;
const blueprintMarks: Array<{ cx: number; cy: number; type: 'cross' | 'circle' | 'square'; delay: string; size: number }> = [];
for (let gx = 1; gx < 8; gx++) {
  for (let gy = 1; gy < 5; gy++) {
    if (srand(seed + 900, gx * 7 + gy) > 0.6) {
      const types = ['cross', 'circle', 'square'] as const;
      blueprintMarks.push({
        cx: gx * gridSpacingX,
        cy: gy * gridSpacingY,
        type: types[Math.floor(srand(seed + 900, gx * 13 + gy) * 3)],
        delay: ((gx + gy) * 0.12).toFixed(1),
        size: 4 + srand(seed + 900, gx * 7 + gy + 50) * 4,
      });
    }
  }
}

// Blueprint measurement lines
const bpMeasureCount = 3;
const bpMeasures = Array.from({ length: bpMeasureCount }, (_, i) => {
  const isHorizontal = srand(seed + 910, i) > 0.5;
  const pos = 0.2 + srand(seed + 910, i + 10) * 0.6;
  const start = 0.1 + srand(seed + 910, i + 20) * 0.2;
  const end = 0.7 + srand(seed + 910, i + 30) * 0.2;
  return {
    x1: isHorizontal ? start * width : pos * width,
    y1: isHorizontal ? pos * height : start * height,
    x2: isHorizontal ? end * width : pos * width,
    y2: isHorizontal ? pos * height : end * height,
    delay: (0.5 + i * 0.3).toFixed(1),
  };
});

// Blueprint component boxes
const bpBoxCount = 3;
const bpBoxes = Array.from({ length: bpBoxCount }, (_, i) => {
  const bw = 60 + srand(seed + 920, i) * 80;
  const bh = 25 + srand(seed + 920, i + 5) * 30;
  return {
    x: 80 + srand(seed + 920, i + 10) * (width - 220),
    y: 40 + srand(seed + 920, i + 15) * (height - 100),
    w: bw,
    h: bh,
    delay: (0.3 + i * 0.25).toFixed(1),
  };
});

// --- Signal: concentric wave rings from emitters ---
const emitterCount = 3 + Math.floor(srand(seed + 1000, 0) * 2);
const emitters = Array.from({ length: emitterCount }, (_, i) => {
  const cx = width * (0.15 + srand(seed + 1000, i * 4) * 0.7);
  const cy = height * (0.2 + srand(seed + 1000, i * 4 + 1) * 0.6);
  const ringCount = 3 + Math.floor(srand(seed + 1000, i * 4 + 2) * 2);
  return {
    cx,
    cy,
    ringCount,
    delay: (i * 0.5).toFixed(1),
    maxR: 30 + srand(seed + 1000, i * 4 + 3) * 50,
    hue: Math.round(30 + srand(seed + 1000, i + 20) * 30),
  };
});

// Signal connection lines between emitters
const signalLinks: Array<{ x1: number; y1: number; x2: number; y2: number; delay: string }> = [];
for (let i = 0; i < emitters.length; i++) {
  for (let j = i + 1; j < emitters.length; j++) {
    if (srand(seed + 1010, i * 5 + j) > 0.4) {
      signalLinks.push({
        x1: emitters[i].cx,
        y1: emitters[i].cy,
        x2: emitters[j].cx,
        y2: emitters[j].cy,
        delay: (0.8 + (i + j) * 0.2).toFixed(1),
      });
    }
  }
}

// --- Cockpit: dashboard with panels, gauges, and status indicators ---
const cpPanelCount = 4;
const cpPanels = Array.from({ length: cpPanelCount }, (_, i) => {
  const pw = 100 + srand(seed + 1100, i * 5) * 100;
  const ph = 35 + srand(seed + 1100, i * 5 + 1) * 45;
  return {
    x: 30 + srand(seed + 1100, i * 5 + 2) * (width - pw - 60),
    y: 15 + srand(seed + 1100, i * 5 + 3) * (height - ph - 30),
    w: pw,
    h: ph,
    delay: (i * 0.25).toFixed(1),
    hue: Math.round(240 + srand(seed + 1100, i * 5 + 4) * 40),
  };
});

const cpGauges = cpPanels.flatMap((p, pi) => {
  const count = 2 + Math.floor(srand(seed + 1110, pi) * 2);
  return Array.from({ length: count }, (_, gi) => ({
    cx: p.x + p.w * (0.2 + gi * 0.25),
    cy: p.y + p.h * 0.55,
    r: 6 + srand(seed + 1110, pi * 4 + gi) * 5,
    fill: 0.3 + srand(seed + 1110, pi * 4 + gi + 10) * 0.55,
    delay: (parseFloat(p.delay) + 0.3 + gi * 0.1).toFixed(1),
    hue: p.hue,
  }));
});

const cpStatusCount = 10;
const cpDots = Array.from({ length: cpStatusCount }, (_, i) => ({
  cx: 20 + srand(seed + 1120, i * 3) * (width - 40),
  cy: 10 + srand(seed + 1120, i * 3 + 1) * (height - 20),
  r: 1.5 + srand(seed + 1120, i * 3 + 2),
  hue: [140, 45, 260][Math.floor(srand(seed + 1120, i + 20) * 3)],
  delay: (srand(seed + 1120, i + 30) * 5).toFixed(1),
}));

const cpLinks: Array<{ x1: number; y1: number; x2: number; y2: number; delay: string }> = [];
for (let i = 0; i < cpPanels.length; i++) {
  for (let j = i + 1; j < cpPanels.length; j++) {
    if (srand(seed + 1130, i * 5 + j) > 0.35) {
      cpLinks.push({
        x1: cpPanels[i].x + cpPanels[i].w / 2,
        y1: cpPanels[i].y + cpPanels[i].h / 2,
        x2: cpPanels[j].x + cpPanels[j].w / 2,
        y2: cpPanels[j].y + cpPanels[j].h / 2,
        delay: (0.6 + (i + j) * 0.15).toFixed(1),
      });
    }
  }
}

// --- Scaffold: modular blocks with connectors ---
const scModuleCount = 6;
const scModules = Array.from({ length: scModuleCount }, (_, i) => {
  const mw = 50 + srand(seed + 1200, i * 5) * 80;
  const mh = 25 + srand(seed + 1200, i * 5 + 1) * 35;
  return {
    x: 30 + srand(seed + 1200, i * 5 + 2) * (width - mw - 60),
    y: 15 + srand(seed + 1200, i * 5 + 3) * (height - mh - 30),
    w: mw,
    h: mh,
    delay: (i * 0.2).toFixed(1),
    hue: Math.round(255 + srand(seed + 1200, i * 5 + 4) * 30),
    lightness: Math.round(25 + srand(seed + 1200, i + 20) * 15),
  };
});

const scConnectors = scModules.flatMap((m, mi) => {
  const positions = [
    { cx: m.x, cy: m.y + m.h / 2 },
    { cx: m.x + m.w, cy: m.y + m.h / 2 },
    { cx: m.x + m.w / 2, cy: m.y },
    { cx: m.x + m.w / 2, cy: m.y + m.h },
  ];
  return positions
    .filter((_, pi) => srand(seed + 1210, mi * 4 + pi) > 0.4)
    .map((pos, pi) => ({
      ...pos,
      delay: (parseFloat(m.delay) + 0.3).toFixed(1),
    }));
});

const scLinks: Array<{ x1: number; y1: number; x2: number; y2: number; delay: string }> = [];
for (let i = 0; i < scModules.length; i++) {
  for (let j = i + 1; j < scModules.length; j++) {
    const mi = scModules[i];
    const mj = scModules[j];
    const dx = (mi.x + mi.w / 2) - (mj.x + mj.w / 2);
    const dy = (mi.y + mi.h / 2) - (mj.y + mj.h / 2);
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < Math.min(width, height) * 0.55) {
      scLinks.push({
        x1: mi.x + mi.w / 2,
        y1: mi.y + mi.h / 2,
        x2: mj.x + mj.w / 2,
        y2: mj.y + mj.h / 2,
        delay: (Math.max(parseFloat(mi.delay), parseFloat(mj.delay)) + 0.3).toFixed(1),
      });
    }
  }
}

// --- Orbit: central core with orbital rings and satellites ---
const orbitCx = width / 2;
const orbitCy = height / 2;
const orbitRingCount = 3;
const orbitRings = Array.from({ length: orbitRingCount }, (_, i) => ({
  rx: width * (0.12 + i * 0.11),
  ry: height * (0.15 + i * 0.12),
  rotation: Math.round(-15 + srand(seed + 1300, i) * 30),
  delay: (i * 0.3).toFixed(1),
}));

const orbitSats = orbitRings.flatMap((ring, ri) => {
  const count = 2 + Math.floor(srand(seed + 1310, ri) * 2);
  return Array.from({ length: count }, (_, si) => {
    const angle = (Math.PI * 2 * si) / count + srand(seed + 1310, ri * 4 + si) * 0.8;
    const rad = (ring.rotation * Math.PI) / 180;
    const px = Math.cos(angle) * ring.rx;
    const py = Math.sin(angle) * ring.ry;
    const cx = orbitCx + px * Math.cos(rad) - py * Math.sin(rad);
    const cy = orbitCy + px * Math.sin(rad) + py * Math.cos(rad);
    return {
      cx,
      cy,
      r: 3 + srand(seed + 1310, ri * 4 + si + 10) * 4,
      delay: (parseFloat(ring.delay) + si * 0.2).toFixed(1),
      hue: Math.round(250 + ri * 15 + srand(seed + 1310, ri * 4 + si + 20) * 20),
      drift: 4 + srand(seed + 1310, ri * 4 + si + 15) * 6,
    };
  });
});

const orbitLinks = orbitSats.map((s, i) => ({
  x1: orbitCx,
  y1: orbitCy,
  x2: s.cx,
  y2: s.cy,
  delay: (parseFloat(s.delay) + 0.2).toFixed(1),
}));
---

