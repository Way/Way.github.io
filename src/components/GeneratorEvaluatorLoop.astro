---
/**
 * Generator-Evaluator Loop: Iterative improvement cycle.
 * Shows how output quality improves over multiple rounds.
 */

const W = 720;
const H = 340;

// Two main nodes
const genX = 200;
const evalX = 520;
const nodeY = 120;
const nodeR = 36;

// Iteration quality bars
const barStartX = 160;
const barW = 400;
const barY = 230;
const barH = 14;
const iterations = [
  { round: 1, quality: 0.35, label: 'Runde 1' },
  { round: 2, quality: 0.6, label: 'Runde 2' },
  { round: 3, quality: 0.82, label: 'Runde 3' },
  { round: 4, quality: 0.95, label: 'Runde 4' },
];
---

<figure class="gen-eval-loop">
  <svg
    viewBox={`0 0 ${W} ${H}`}
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Diagramm: Generator-Evaluator Loop mit iterativer Qualitätsverbesserung"
    width="100%"
    preserveAspectRatio="xMidYMid meet"
  >
    <title>Generator-Evaluator Loop</title>
    <defs>
      <marker
        id="arrowhead-loop"
        markerWidth="8"
        markerHeight="6"
        refX="7"
        refY="3"
        orient="auto"
      >
        <polygon points="0 0, 8 3, 0 6" fill="var(--accent)" opacity="0.6" />
      </marker>
    </defs>

    {/* Top arrow: Generator → Evaluator */}
    <path
      d={`M${genX + nodeR + 6},${nodeY - 12} Q${(genX + evalX) / 2},${nodeY - 55} ${evalX - nodeR - 10},${nodeY - 12}`}
      fill="none"
      stroke="var(--accent)"
      stroke-width="1.5"
      opacity="0.4"
      marker-end="url(#arrowhead-loop)"
    />
    <text
      x={(genX + evalX) / 2}
      y={nodeY - 48}
      text-anchor="middle"
      class="loop-arrow-label"
    >
      Code / Lösung
    </text>

    {/* Bottom arrow: Evaluator → Generator */}
    <path
      d={`M${evalX - nodeR - 6},${nodeY + 12} Q${(genX + evalX) / 2},${nodeY + 55} ${genX + nodeR + 10},${nodeY + 12}`}
      fill="none"
      stroke="var(--accent)"
      stroke-width="1.5"
      opacity="0.4"
      marker-end="url(#arrowhead-loop)"
    />
    <text
      x={(genX + evalX) / 2}
      y={nodeY + 62}
      text-anchor="middle"
      class="loop-arrow-label"
    >
      Kritik / Feedback
    </text>

    {/* Generator node */}
    <circle cx={genX} cy={nodeY} r={nodeR + 8} fill="none"
      stroke="hsla(220, 50%, 55%, 0.12)" stroke-width="1" />
    <circle cx={genX} cy={nodeY} r={nodeR}
      class="loop-node" style="--node-hue: 220" />
    <text x={genX} y={nodeY - 2} text-anchor="middle" class="loop-label">Generator</text>
    <text x={genX} y={nodeY + 14} text-anchor="middle" class="loop-sublabel">Schreibt Code</text>

    {/* Evaluator node */}
    <circle cx={evalX} cy={nodeY} r={nodeR + 8} fill="none"
      stroke="hsla(0, 50%, 55%, 0.12)" stroke-width="1" />
    <circle cx={evalX} cy={nodeY} r={nodeR}
      class="loop-node" style="--node-hue: 0" />
    <text x={evalX} y={nodeY - 2} text-anchor="middle" class="loop-label">Evaluator</text>
    <text x={evalX} y={nodeY + 14} text-anchor="middle" class="loop-sublabel">Kritisiert</text>

    {/* Quality indicator label */}
    <text x={barStartX - 10} y={barY - 12} text-anchor="end" class="loop-quality-header">Qualität</text>

    {/* Iteration quality bars */}
    {iterations.map((it, i) => {
      const y = barY + i * (barH + 6);
      const filledW = barW * it.quality;
      return (
        <g>
          {/* Background bar */}
          <rect x={barStartX} y={y} width={barW} height={barH} rx={3}
            class="loop-bar-bg" />
          {/* Filled bar */}
          <rect x={barStartX} y={y} width={filledW} height={barH} rx={3}
            class="loop-bar-fill"
            style={`opacity: ${0.5 + it.quality * 0.5}`} />
          {/* Label */}
          <text x={barStartX - 10} y={y + 11} text-anchor="end" class="loop-round-label">
            {it.label}
          </text>
          {/* Percentage */}
          <text x={barStartX + filledW + 8} y={y + 11} class="loop-pct">
            {Math.round(it.quality * 100)}%
          </text>
        </g>
      );
    })}
  </svg>
  <figcaption class="chart-caption">
    Generator-Evaluator Loop: Mit jeder Runde steigt die Qualität, weil der Evaluator den Generator herausfordert.
  </figcaption>
</figure>

<style>
  .gen-eval-loop {
    margin: 2.5em 0;
    padding: 0;
  }

  .gen-eval-loop svg {
    display: block;
  }

  .loop-node {
    fill: rgba(148, 155, 175, 0.08);
    stroke: hsla(var(--node-hue, 220), 50%, 55%, 0.4);
    stroke-width: 2;
  }

  :where(.dark, .dark *) .loop-node {
    fill: rgba(148, 155, 175, 0.1);
  }

  .loop-label {
    fill: rgb(var(--black));
    font-family: 'Atkinson', sans-serif;
    font-size: 13px;
    font-weight: 700;
  }

  .loop-sublabel {
    fill: rgb(var(--gray));
    font-family: 'Atkinson', sans-serif;
    font-size: 10px;
  }

  .loop-arrow-label {
    fill: var(--accent);
    font-family: 'Atkinson', sans-serif;
    font-size: 10px;
    font-weight: 700;
  }

  .loop-bar-bg {
    fill: rgb(var(--gray-light));
  }

  :where(.dark, .dark *) .loop-bar-bg {
    fill: rgba(148, 155, 175, 0.12);
  }

  .loop-bar-fill {
    fill: var(--accent);
  }

  .loop-round-label {
    fill: rgb(var(--gray));
    font-family: 'Atkinson', sans-serif;
    font-size: 11px;
  }

  .loop-quality-header {
    fill: rgb(var(--gray));
    font-family: 'Atkinson', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .loop-pct {
    fill: var(--accent);
    font-family: 'Atkinson', sans-serif;
    font-size: 10px;
    font-weight: 700;
  }

  .chart-caption {
    text-align: center;
    font-size: 14px;
    color: rgb(var(--gray));
    margin-top: 0.75em;
    line-height: 1.4;
  }
</style>
