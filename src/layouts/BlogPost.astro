---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import BlogPostIntro from '../components/BlogPostIntro.astro';
import HeroVisual from '../components/HeroVisual.astro';
import '../styles/global.css';

type Props = CollectionEntry<'blog'>['data'] & { image?: string };

const { title, description, pubDate, updatedDate, prompt, visualTheme, image } = Astro.props;
---

<html lang="de">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body>
    <Header />
    <main>
      <article>
        <header class="post-header">
          <div class="post-meta-row">
            <div class="eyebrow">
              <span class="dot"></span>
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <span class="updated">
                  · aktualisiert <FormattedDate date={updatedDate} />
                </span>
              )}
            </div>
          </div>
          <h1 class="post-title">{title}</h1>
          {description && <p class="post-lede">{description}</p>}
        </header>

        <div class="post-visual">
          <HeroVisual
            title={title}
            pubDate={pubDate}
            visualTheme={visualTheme}
            variant="detail"
          />
        </div>

        {prompt && <BlogPostIntro content={prompt} />}

        <div class="post-body prose">
          <slot />
        </div>
      </article>
      <div id="img-zoom-overlay" class="img-zoom-overlay"></div>
    </main>
    <Footer />

    <style>
      main {
        width: 100%;
        max-width: 760px;
        margin: 0 auto;
        padding: 3.5rem 1.5rem 2rem;
      }
      .post-header {
        margin-bottom: 2.5rem;
      }
      .post-meta-row {
        margin-bottom: 1.5rem;
      }
      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--ink-faint);
      }
      .eyebrow .dot {
        display: inline-block;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--terracotta);
      }
      .updated {
        color: var(--ink-faint);
      }
      .post-title {
        font-family: 'Newsreader', Georgia, serif;
        font-weight: 400;
        font-size: clamp(2.4rem, 5.4vw, 3.8rem);
        line-height: 1.05;
        letter-spacing: -0.02em;
        margin: 0 0 1.25rem;
        color: var(--ink);
        text-wrap: balance;
      }
      .post-title em {
        font-style: italic;
        color: var(--accent);
      }
      .post-lede {
        font-family: 'Newsreader', Georgia, serif;
        font-size: clamp(1.15rem, 2vw, 1.45rem);
        line-height: 1.45;
        color: var(--ink-dim);
        margin: 0;
        max-width: 60ch;
      }
      .post-visual {
        margin: 0 0 2.5rem;
      }
      .post-visual :global(.hero-visual) {
        border-radius: 2px;
        max-height: 320px;
      }
      .post-visual :global(.hero-visual__overlay) {
        background: linear-gradient(
          to top,
          rgba(0, 0, 0, 0.25) 0%,
          transparent 60%
        );
      }
      .post-body {
        width: 100%;
        max-width: 100%;
        margin: 0;
        padding: 0;
        font-size: 1.05rem;
        line-height: 1.7;
      }
      .post-body :global(h2),
      .post-body :global(h3) {
        position: relative;
        scroll-margin-top: 2rem;
      }
      .post-body :global(h2) {
        margin-top: 2.5em;
        margin-bottom: 0.6em;
      }
      .post-body :global(h3) {
        margin-top: 2em;
      }
      .post-body :global(.heading-anchor) {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-weight: 400;
        font-size: 0.6em;
        color: var(--ink-faint);
        text-decoration: none;
        margin-left: 0.5rem;
        padding: 0 0.25rem;
        opacity: 0;
        transition: opacity 0.15s, color 0.15s;
        vertical-align: middle;
        position: relative;
        top: -0.1em;
      }
      .post-body :global(h2:hover .heading-anchor),
      .post-body :global(h3:hover .heading-anchor),
      .post-body :global(.heading-anchor:focus-visible) {
        opacity: 1;
      }
      .post-body :global(.heading-anchor:hover) {
        color: var(--accent);
      }
      .post-body :global(.heading-anchor.copied)::after {
        content: "kopiert";
        position: absolute;
        left: calc(100% + 0.4rem);
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--moss);
        white-space: nowrap;
      }
      .post-body :global(p) {
        margin-bottom: 1.25em;
      }
      .post-body :global(ul),
      .post-body :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.5em;
      }
      .post-body :global(li) {
        margin-bottom: 0.5em;
      }
      .post-body :global(hr) {
        margin: 3rem auto;
        border: none;
        height: 1px;
        background: var(--border);
        max-width: 60%;
        position: relative;
      }

      @media (max-width: 720px) {
        main {
          padding: 2rem 1rem 1rem;
        }
        .post-header {
          margin-bottom: 2rem;
        }
        .post-body {
          font-size: 1rem;
        }
      }

      /* Image zoom */
      .post-body :global(img) {
        cursor: zoom-in;
        transition: transform 0.3s cubic-bezier(0.2, 0, 0.2, 1);
      }
      .post-body :global(figure) {
        cursor: zoom-in;
        transition: transform 0.3s cubic-bezier(0.2, 0, 0.2, 1);
      }
      .img-zoom-overlay {
        position: fixed;
        inset: 0;
        background: rgba(20, 21, 28, 0.82);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s cubic-bezier(0.2, 0, 0.2, 1);
        z-index: 99;
      }
      .img-zoom-overlay.active {
        opacity: 1;
        pointer-events: auto;
        cursor: zoom-out;
      }
      :global(.img-zoomed) {
        position: relative;
        z-index: 100;
        cursor: zoom-out !important;
        background: var(--surface);
        padding: 1rem;
      }
    </style>

    <script>
      function initImageZoom() {
        const overlay = document.getElementById('img-zoom-overlay');
        if (!overlay) return;
        let zoomedEl: HTMLElement | null = null;
        let originalTransform = '';

        function zoomIn(el: HTMLElement) {
          if (zoomedEl) return;
          zoomedEl = el;
          const rect = el.getBoundingClientRect();
          const viewportW = window.innerWidth;
          const viewportH = window.innerHeight;
          const padding = 40;
          const maxW = viewportW - padding * 2;
          const maxH = viewportH - padding * 2;
          let maxNaturalScale = 3;
          if (el instanceof HTMLImageElement) {
            maxNaturalScale = Math.min(
              el.naturalWidth / rect.width,
              el.naturalHeight / rect.height
            );
          }
          const fitScale = Math.min(maxW / rect.width, maxH / rect.height);
          const scale = Math.min(fitScale, maxNaturalScale, 3);
          const imgCenterX = rect.left + rect.width / 2;
          const imgCenterY = rect.top + rect.height / 2;
          const translateX = viewportW / 2 - imgCenterX;
          const translateY = viewportH / 2 - imgCenterY;
          originalTransform = el.style.transform;
          el.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
          el.classList.add('img-zoomed');
          overlay.classList.add('active');
        }

        function zoomOut() {
          if (!zoomedEl) return;
          zoomedEl.style.transform = originalTransform;
          zoomedEl.classList.remove('img-zoomed');
          overlay.classList.remove('active');
          zoomedEl = null;
          originalTransform = '';
        }

        document.querySelectorAll('.post-body img, .post-body figure').forEach((el) => {
          el.addEventListener('click', (e) => {
            e.stopPropagation();
            e.preventDefault();
            const target = el as HTMLElement;
            if (zoomedEl === target) {
              zoomOut();
            } else {
              zoomOut();
              zoomIn(target);
            }
          });
        });

        overlay.addEventListener('click', zoomOut);
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') zoomOut();
        });
      }

      initImageZoom();
      document.addEventListener('astro:after-swap', initImageZoom);

      function initHeadingAnchors() {
        const headings = document.querySelectorAll<HTMLHeadingElement>(
          '.post-body h2[id], .post-body h3[id]'
        );
        headings.forEach((heading) => {
          if (heading.querySelector('.heading-anchor')) return;
          const link = document.createElement('a');
          link.href = `#${heading.id}`;
          link.className = 'heading-anchor';
          link.setAttribute('aria-label', `Direktlink zu „${heading.textContent?.trim() ?? ''}“`);
          link.textContent = '#';
          link.addEventListener('click', async (event) => {
            event.preventDefault();
            const url = `${window.location.origin}${window.location.pathname}#${heading.id}`;
            history.replaceState(null, '', `#${heading.id}`);
            heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
            try {
              if (navigator.clipboard && window.isSecureContext) {
                await navigator.clipboard.writeText(url);
              } else {
                const ta = document.createElement('textarea');
                ta.value = url;
                ta.style.position = 'fixed';
                ta.style.opacity = '0';
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
              }
              link.classList.add('copied');
              window.setTimeout(() => link.classList.remove('copied'), 1500);
            } catch {
              /* ignore — anchor still works */
            }
          });
          heading.appendChild(link);
        });

        if (window.location.hash) {
          const id = decodeURIComponent(window.location.hash.slice(1));
          const target = document.getElementById(id);
          if (target) {
            requestAnimationFrame(() => {
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
          }
        }
      }

      initHeadingAnchors();
      document.addEventListener('astro:after-swap', initHeadingAnchors);
    </script>
  </body>
</html>
