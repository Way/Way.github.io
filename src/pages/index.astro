---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import HeroVisual from '../components/HeroVisual.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [featured, ...rest] = posts;
---

<!doctype html>
<html lang="de">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="masthead">
        <div class="eyebrow">Notizen · Essays · Werkstatt</div>
        <h1 class="masthead-title">People. Life. <em>Technology.</em></h1>
        <p class="masthead-lede">
          Notizen aus dem Engineering-Alltag. AI, Software, Kultur.<br /> Immer mit
          Blick auf den Menschen.
        </p>
      </section>

      {
        featured && (
          <a href={`/blog/${featured.id}/`} class="featured">
            <div class="featured-visual">
              <HeroVisual
                title={featured.data.title}
                pubDate={featured.data.pubDate}
                visualTheme={featured.data.visualTheme}
                variant="featured"
              />
            </div>
            <div class="featured-meta">
              <div class="eyebrow">
                Aktuell · <FormattedDate date={featured.data.pubDate} />
              </div>
              <h2 class="featured-title">{featured.data.title}</h2>
              <p class="featured-desc">{featured.data.description}</p>
              <span class="read-link">weiterlesen</span>
            </div>
          </a>
        )
      }

      <ol class="archive" aria-label="Weitere Beiträge">
        {
          rest.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`}>
                <div class="archive-thumb">
                  <HeroVisual
                    title={post.data.title}
                    pubDate={post.data.pubDate}
                    visualTheme={post.data.visualTheme}
                    variant="card"
                  />
                </div>
                <div class="archive-text">
                  <time class="archive-date">
                    <FormattedDate date={post.data.pubDate} />
                  </time>
                  <h3 class="archive-title">{post.data.title}</h3>
                  <p class="archive-desc">{post.data.description}</p>
                </div>
              </a>
            </li>
          ))
        }
      </ol>
    </main>
    <Footer />
    <style>
      main {
        width: 100%;
        max-width: 1140px;
        margin: 0 auto;
        padding: 4rem 1.5rem 2rem;
      }
      .masthead {
        max-width: 720px;
        margin-bottom: 4rem;
      }
      .eyebrow {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--ink-faint);
        margin-bottom: 1.5rem;
      }
      .masthead-title {
        font-family: 'Newsreader', Georgia, serif;
        font-weight: 400;
        font-size: clamp(2.6rem, 6vw, 4.4rem);
        line-height: 1.02;
        letter-spacing: -0.02em;
        margin: 0 0 1.25rem;
      }
      .masthead-title em {
        font-style: italic;
        color: var(--accent);
        font-weight: 400;
      }
      .masthead-lede {
        font-family: 'Newsreader', Georgia, serif;
        font-size: clamp(1.1rem, 1.6vw, 1.35rem);
        line-height: 1.5;
        color: var(--ink-dim);
        max-width: 620px;
        margin: 0;
      }

      /* Featured */
      .featured {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
        gap: 3rem;
        padding: 2.5rem 0;
        border-top: 1px solid var(--border-strong);
        border-bottom: 1px solid var(--border);
        text-decoration: none;
        color: inherit;
        margin-bottom: 4rem;
      }
      .featured-visual {
        align-self: start;
      }
      .featured-visual :global(.hero-visual) {
        border-radius: 2px;
      }
      .featured-meta {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding-top: 0.25rem;
      }
      .featured-meta .eyebrow {
        margin-bottom: 0;
        color: var(--terracotta);
      }
      .featured-title {
        font-family: 'Newsreader', Georgia, serif;
        font-weight: 400;
        font-size: clamp(2rem, 3.5vw, 2.8rem);
        line-height: 1.08;
        letter-spacing: -0.01em;
        margin: 0;
        color: var(--ink);
        text-wrap: balance;
      }
      .featured-desc {
        font-size: 1.05rem;
        line-height: 1.55;
        color: var(--ink-dim);
        margin: 0;
      }
      .read-link {
        margin-top: auto;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--accent);
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }
      .read-link::after {
        content: '→';
        transition: transform 0.2s;
      }
      .featured:hover .read-link::after {
        transform: translateX(4px);
      }
      .featured:hover .featured-title {
        color: var(--accent);
      }

      /* Archive list */
      .archive {
        list-style: none;
        padding: 0;
        margin: 0;
        border-top: 1px solid var(--border);
      }
      .archive li {
        border-bottom: 1px solid var(--border);
        margin: 0;
      }
      .archive li a {
        display: grid;
        grid-template-columns: 200px minmax(0, 1fr);
        gap: 2rem;
        padding: 1.75rem 1rem 1.75rem 0;
        margin: 0 -1rem 0 0;
        text-decoration: none;
        color: inherit;
        transition:
          background-color 0.2s,
          padding-left 0.2s;
        border-left: 2px solid transparent;
      }
      .archive li a:hover {
        background-color: var(--accent-soft);
        padding-left: 1rem;
        border-left-color: var(--accent);
      }
      .archive-thumb {
        align-self: start;
      }
      .archive-thumb :global(.hero-visual) {
        border-radius: 2px;
      }
      .archive-text {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .archive-date {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--ink-faint);
      }
      .archive-title {
        font-family: 'Newsreader', Georgia, serif;
        font-weight: 400;
        font-size: clamp(1.4rem, 2.2vw, 1.8rem);
        line-height: 1.15;
        letter-spacing: -0.01em;
        margin: 0;
        color: var(--ink);
        text-wrap: balance;
      }
      .archive li a:hover .archive-title {
        color: var(--accent);
      }
      .archive-desc {
        font-size: 0.98rem;
        line-height: 1.55;
        color: var(--ink-dim);
        margin: 0;
        max-width: 60ch;
      }

      @media (max-width: 860px) {
        main {
          padding: 2.5rem 1rem 1rem;
        }
        .masthead {
          margin-bottom: 2.5rem;
        }
        .featured {
          grid-template-columns: 1fr;
          gap: 1.5rem;
          padding: 2rem 0;
          margin-bottom: 2.5rem;
        }
        .archive li a {
          grid-template-columns: 110px minmax(0, 1fr);
          gap: 1.25rem;
          padding: 1.5rem 0;
        }
        .archive li a:hover {
          padding-left: 0;
          padding-right: 0;
          margin: 0;
        }
      }
      @media (max-width: 520px) {
        .archive li a {
          grid-template-columns: 1fr;
          gap: 0.75rem;
        }
      }
    </style>
  </body>
</html>
